# =============================================================================
# Tiflux GLPI Migrator - Configuração
# =============================================================================
# Copie este arquivo para .env e preencha com suas credenciais.
# IMPORTANTE: Nunca commite o arquivo .env com credenciais reais!
# =============================================================================

# -----------------------------------------------------------------------------
# TIFLUX API (obrigatório)
# -----------------------------------------------------------------------------
# URL base da API Tiflux (geralmente https://api.tiflux.com)
TIFLUX_BASE_URL=https://api.tiflux.com

# Token de acesso da API Tiflux
# Obtenha em: Tiflux > Configurações > Integrações > API
TIFLUX_API_TOKEN=seu_token_aqui

# -----------------------------------------------------------------------------
# GLPI API (obrigatório para importação)
# -----------------------------------------------------------------------------
# URL do GLPI (ex: http://localhost:8080 para homologação local)
GLPI_BASE_URL=http://localhost:8080

# Credenciais de administrador do GLPI
GLPI_USER=glpi
GLPI_PASS=glpi

# Autenticação alternativa via User Token (opcional)
# Se preenchido, usa token ao invés de usuário/senha
GLPI_USER_TOKEN=

# App Token do GLPI (opcional, se seu GLPI exigir)
GLPI_APP_TOKEN=

# -----------------------------------------------------------------------------
# GLPI Database (usado pelo Docker Compose)
# -----------------------------------------------------------------------------
# Configurações do banco MySQL para o ambiente de homologação
GLPI_DB_HOST=db
GLPI_DB_PORT=3306
GLPI_DB_NAME=glpi
GLPI_DB_USER=glpi
GLPI_DB_PASSWORD=glpi

# -----------------------------------------------------------------------------
# GLPI API Paths (geralmente não precisa alterar)
# -----------------------------------------------------------------------------
GLPI_REST_LEGACY_INIT_PATH=/apirest.php/initSession
GLPI_REST_V2_PATH=/apirest.php/v2
GLPI_API_TOKEN_V2=

# -----------------------------------------------------------------------------
# Configurações Locais (opcional)
# -----------------------------------------------------------------------------
# Diretório para armazenar dados da migração
MIGRATOR_DATA_DIR=data
